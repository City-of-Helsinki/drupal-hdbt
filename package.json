{
  "name": "hdbt",
  "version": "1.1.0",
  "description": "Theme builder configuration for HDBT Drupal 10 theme",
  "author": "Druid",
  "license": "MIT",
  "repository": "github:City-of-Helsinki/drupal-hdbt",
  "scripts": {
    "dev": "node theme-builder.mjs --watch --dev",
    "build": "npm run format:js --loglevel=silent && npm run lint -s && node theme-builder.mjs",
    "preinstall": "npx update-browserslist-db@latest",
    "lint:scss": "npx postcss \"src/scss/**/*.scss\" --syntax postcss-scss --use css-declaration-sorter --replace --no-map && npm run lint:stylelint",
    "lint:stylelint": "npx stylelint \"src/scss/**/*.scss\" --config ./theme-builder/.stylelintrc.yaml --formatter --fix",
    "lint:js": "biome check --write --assist-enabled=true src/js/",
    "format:js": "biome format --write src/js/",
    "lint": "npm-run-all --parallel lint:scss lint:js -s",
    "full-reference": "./node_modules/.bin/dotenvx run -- node backstop/backstop_dynamic_config full reference",
    "full-test": "./node_modules/.bin/dotenvx run -- node backstop/backstop_dynamic_config full test",
    "full-approve": "./node_modules/.bin/dotenvx run -- node backstop/backstop_dynamic_config full approve",
    "fast-reference": "./node_modules/.bin/dotenvx run -- node backstop/backstop_dynamic_config fast reference",
    "fast-test": "./node_modules/.bin/dotenvx run -- node backstop/backstop_dynamic_config fast test",
    "fast-approve": "./node_modules/.bin/dotenvx run -- node backstop/backstop_dynamic_config fast approve",
    "validate-ts": "tsc --noEmit"
  },
  "@comment dependencies": [
    "The following packages were updated manually.",
    "Remove this section once the dependencies have been updated in their respective upstream packages.",
    {
      "ajv": ">=8.18.0, dependency of hds-react",
      "basic-ftp": ">=5.2.3, dependency of backstopjs",
      "tar-fs": ">=3.0.9, dependency of backstopjs",
      "diff": "^8.0.3, dependency of backstopjs",
      "minimatch": ">=10.2.1, dependency of hds-core (eslint)",
      "yauzl": "^3.2.1, dependency of backstopjs"
    }
  ],
  "overrides": {
    "basic-ftp": "^5.2.3",
    "diff": "^8.0.3",
    "ajv": "^8.18.0",
    "minimatch": "^10.2.1",
    "yauzl": "^3.2.1"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.15.0",
    "@elastic/elasticsearch": "^9.0.2",
    "@hdbt/theme-builder": "file:theme-builder",
    "@sentry/react": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^17.0.34",
    "@types/react-dom": "^17.0.11",
    "backstopjs": "^6.2.2",
    "chokidar": "^4.0.3",
    "classnames": "^2.3.1",
    "focus-trap": "^7.5.4",
    "glob": "^11.0.0",
    "hds-core": "5.0.0",
    "hds-design-tokens": "5.0.0",
    "hds-react": "5.0.0",
    "lodash-es": "^4.17.21",
    "hyphenopoly": "^6.0.0",
    "jotai": "^2.6.0",
    "mustache": "^4.2.0",
    "npm-run-all2": "^8.0.4",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "swr": "2.3.6",
    "tar-fs": ">=3.0.9",
    "typescript": "6.0.2"
  },
  "browserslist": [
    "last 3 major versions",
    "> 1%",
    "not dead"
  ],
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}"
    ],
    "coveragePathIgnorePatterns": [
      "node_modules",
      "<rootDir>/src/index.tsx",
      "<rootDir>/src/enum/*",
      "<rootDir>/src/types/*"
    ]
  }
}
