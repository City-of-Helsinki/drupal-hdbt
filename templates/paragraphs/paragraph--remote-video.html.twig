{% set paragraph_title = content.field_remote_video_title %}
{% set paragraph_desc = content.field_remote_video_description %}
{% set video = content.field_remote_video %}
{% set video_title = content.field_remote_video_video_title %}
{% set video_desc = content.field_remote_video_video_desc %}

{% if not paragraph_title|render and not paragraph_desc|render %}
  {% set header_class = 'component--no-header' %}
{% endif %}

{# Do not try to render any non-public videos. #}
{% if is_hidden_video %}
  <div class="hidden-private-video"></div>
{% else %}
  {% block paragraph %}
    {% include '@hdbt/component/remote-video.twig' with {
      paragraph_title: paragraph_title,
      paragraph_desc: paragraph_desc,
      video: video,
      video_title: video_title,
      video_desc: video_desc
    }%}
  {% endblock paragraph %}
{% endif %}
