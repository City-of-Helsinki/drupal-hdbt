{% set service_points_title %}
  {% trans with {'context': 'Service units title'}%}Service point{% plural total_rows %}Service points{% endtrans %}
{% endset %}
  

{% embed '@hdbt/component/content-list-with-count.twig' with { 
   title: service_points_title,
}%}
  {% block count_container%}
    {% if total_rows > 1 %}
      {{ total_rows }} {% trans with {'context': 'Service units count'}%}service point{% plural total_rows %}service points{% endtrans %}
    {% elseif total_rows == 0 %}
      {{ 'No results'|t({}, {'context' : 'Unit search no results title'}) }}
    {% endif %}
  {% endblock count_container %}
{% endembed %}