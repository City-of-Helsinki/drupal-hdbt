{% set vehicle_removal_description %}
  <p>{{ 'Use street names to search for areas with vehicle removal requests.'|t({}, {'context': 'Vehicle removal search'}) }}</p>
  <p>{{ 'The search results will show you the location of vehicle removal request signs on the street that you searched for or a street near it.'|t({}, {'context': 'Vehicle removal search'}) }}</p>
{% endset %}
{% embed "@hdbt/misc/component.twig" with
  {
    component_classes: [
      'component--react-search',
      'component--full-width',
      'component--vehicle-removal-search',
    ],
    component_title: 'Find vehicle removal requests'|t({}, {'context': 'Vehicle removal search'}),
    component_description: vehicle_removal_description,
  }
%}
  {% block component_content %}
    {# The React app will load into this div. #}
    <div id="helfi-vehicle-removal-search"></div>
  {% endblock component_content %}
{% endembed %}
